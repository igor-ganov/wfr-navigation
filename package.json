{
  "name": "@web-file-reader/navigation",
  "version": "0.1.0",
  "description": "Headless Lit paging controls (<wfr-viewer-nav>) that auto-hide on inactivity and page with arrow keys, hover, tap and focus.",
  "type": "module",
  "license": "MIT",
  "author": "Igor Ganov",
  "homepage": "https://github.com/igor-ganov/wfr-navigation",
  "repository": { "type": "git", "url": "https://github.com/igor-ganov/wfr-navigation.git" },
  "keywords": ["web-file-reader", "lit", "web-component", "headless", "navigation", "pager"],
  "sideEffects": ["**/*.ts", "**/*.js"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" }
  },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "happy-dom": "^15.11.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": { "access": "public" }
}
